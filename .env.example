# Server
PORT=10000
DATA_DIR=./storage/data
WHATSAPP_AUTH_FOLDER=./storage/auth_publico

# WhatsApp
WHATSAPP_GROUP_ID=
WHATSAPP_LOGIN_METHOD=qr
WHATSAPP_PAIRING_PHONE=
RESET_WHATSAPP_AUTH_ON_START=false
SEND_PRODUCT_IMAGE=true
ALLOW_LINK_ONLY=true
REQUIRE_VERIFIED_IMAGE=true
ALLOW_UNTRUSTED_IMAGE_TESTING=false
ALLOW_PAGE_IMAGE_AS_VERIFIED=true
IMAGE_EXTRACTION_MODE=page_first
IMAGE_MIN_CONFIDENCE=70
IMAGE_MIN_BYTES=10000
IMAGE_MIN_WIDTH=180
IMAGE_MIN_HEIGHT=180
IMAGE_REQUIRE_VALID_HTTP=true
PLAYWRIGHT_IMAGE_FALLBACK=false
PLAYWRIGHT_TIMEOUT_MS=30000
PUBLISH_ONLY_VALIDATED=true
AUTO_START_PUBLISHER=false
AUTO_START_COLLECTOR=true
SEED_TEST_OFFER_ON_START=false

# Automation
SOURCE_PROVIDER=public_sources
DISCOVERY_INTERVAL_MINUTES=45
POST_INTERVAL_MINUTES=45
MAX_POSTS_PER_RUN=5
MAX_LINKS_PER_SOURCE=250
GOOGLE_IMAGE_SEARCH_API_KEY=
GOOGLE_IMAGE_SEARCH_CX=

# Public sources
PUBLIC_SOURCE_URLS=https://ofertasdachloe.com.br/categoria/casa-moveis-e-decoracao,https://ofertasdachloe.com.br/categoria/beleza-e-cuidados-pessoais,https://ofertasdachloe.com.br/categoria/moda-e-acessorios,https://ofertasdachloe.com.br/categoria/infantil-e-brinquedos,https://ofertasdachloe.com.br/categoria/esporte-e-lazer,https://ofertasdachloe.com.br/categoria/supermercado,https://ofertasdachloe.com.br/categoria/games-e-geek
RSS_SOURCE_URLS=

# Broad focus, excluding informatics and automotive
OFFER_KEYWORDS=
BLOCK_KEYWORDS=informatico,informatica,computador,pc,notebook,desktop,monitor,teclado,mouse,placa de video,placa mae,processador,ssd,hd,memoria ram,roteador,impressora,camera,smartphone,celular,iphone,android,automotivo,carro,moto,veiculo,automovel,pneu,oleo,farol,oficina,peca automotiva
MIN_PRICE=1
MAX_PRICE=500
